Bootstrap: docker
From: fedora:42

%setup
    # Create cache directories in container for bind mounts
    mkdir -p ${APPTAINER_ROOTFS}/root/.cache/pip

%post

    dnf -y update

    echo "Installing necessary build tools and dependencies..."
    dnf -y install hostname \
                   vim \
                   wget \
                   bzip2 \
                   git \
                   subversion \
                   patch \
                   mercurial \
                   which \
                   curl \
                   unzip \
                   gcc \
                   gcc-c++ \
                   gfortran \
                   make \
                   cmake \
                   castxml \
                   pandoc \
                   clang \
                   python3.13 \
                   python3.13-devel \
                   boost-devel \
                   libedit-devel \
                   suitesparse-devel \
                   openblas-devel \
                   cppunit-devel \
                   lapack-devel \
                   blas-devel \
                   proj-devel \
                   geos-devel

    # Bootstrap pip for Python 3.13 (no python3.13-pip package in Fedora)
    python3.13 -m ensurepip --upgrade

    # Create installation directory for gimli
    mkdir -p /opt/gimli
    cd /opt/gimli

    echo "Cloning pygimli source..."
    git clone https://github.com/gimli-org/gimli.git

    # Install Python build dependencies (system-wide, no venv needed in container)
    python3.13 -m pip install --upgrade pip setuptools wheel
    python3.13 -m pip install numpy matplotlib scipy
    # Sphinx (needed for cmake to find sphinx-build)
    python3.13 -m pip install sphinx sphinx-book-theme sphinx-design sphinx-togglebutton myst-nb sphinx-gallery pypandoc sphinxcontrib-mermaid sphinx-copybutton
    python3.13 -m pip install pygccxml pyplusplus

    # Check if dev_requirements.txt exists and install
    if [ -f /opt/gimli/gimli/dev_requirements.txt ]; then
        python3.13 -m pip install -r /opt/gimli/gimli/dev_requirements.txt
    fi

    # Build gimli from source (out of source build)
    mkdir -p /opt/gimli/build
    cd /opt/gimli/build

    # Manually download and build Triangle (wget2 has issues with the auto-download)
    mkdir -p /opt/gimli/thirdParty/src/triangle
    cd /opt/gimli/thirdParty/src/triangle
    curl -L -o triangle.zip http://www.netlib.org/voronoi/triangle.zip
    unzip -o triangle.zip
    # Build Triangle as a library (use C89 standard for old K&R code)
    cc -std=gnu89 -O -DLINUX -DTRILIBRARY -DNO_TIMER -fPIC -c triangle.c
    ar r libtriangle.a triangle.o

    # Install Triangle (use dynamic GCC version for path)
    GCC_VERSION=$(gcc -dumpversion)
    DIST_DIR="/opt/gimli/thirdParty/dist-GNU-${GCC_VERSION}-64"
    mkdir -p ${DIST_DIR}/lib
    mkdir -p ${DIST_DIR}/include
    cp libtriangle.a ${DIST_DIR}/lib/
    cp triangle.h ${DIST_DIR}/include/
    cd /opt/gimli/build

    # Get Python 3.13 include path dynamically
    PY_INCLUDE=$(python3.13 -c "import sysconfig; print(sysconfig.get_path('include'))")

    cd /tmp
    curl -LO https://archives.boost.io/release/1.87.0/source/boost_1_87_0.tar.gz
    tar xzf boost_1_87_0.tar.gz
    cd boost_1_87_0
    ./bootstrap.sh --with-python=python3.13
    ./b2 --with-python python=3.13 link=shared install
    ldconfig

    # Return to gimli build directory
    cd /opt/gimli/build

    which castxml
    castxml --version

    cmake ../gimli \
        -DBOOST_ROOT=/usr/local \
        -DPYVERSION=3.13 \
        -DPython_EXECUTABLE=/usr/bin/python3.13 \
        -DPython_INCLUDE_DIR=${PY_INCLUDE} \
        -DTriangle_INCLUDE_DIR=${DIST_DIR}/include \
        -DTriangle_LIBRARIES=${DIST_DIR}/lib/libtriangle.a
    make -j$(nproc) gimli
    make pygimli J=$(nproc)

    # Verify the build
    cd /opt/gimli
    export PYTHONPATH=/opt/gimli/gimli:$PYTHONPATH
    export LD_LIBRARY_PATH=/opt/gimli/build/lib:$LD_LIBRARY_PATH
    python3.13 -c 'import pygimli as pg; print(pg.__version__)'

    # Install additional Python packages
    python3.13 -m pip install numba llvmlite "seaborn>=0.13" cmcrameri
    python3.13 -m pip install shapely cartopy
    python3.13 -m pip install git+https://github.com/obspy/obspy.git
    python3.13 -m pip install seislib
    python3.13 -m pip install astroquery
    python3.13 -m pip install marimo
    python3.13 -m pip install git+https://github.com/inlab-geo/pyfm2d
    python3.13 -m pip install git+https://github.com/inlab-geo/pyrf96
    python3.13 -m pip install git+https://github.com/inlab-geo/pyhk
    python3.13 -m pip install git+https://github.com/inlab-geo/pysurf96
    python3.13 -m pip install git+https://github.com/JuergHauser/PyP223.git
    python3.13 -m pip install smt
    python3.13 -m pip install cofi papermill nbformat
    python3.13 -m pip install jupyterlab
    python3.13 -m pip install notebook
    python3.13 -m pip install --upgrade ipython ipykernel
    python3.13 -m ipykernel install --name "python3"

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONPATH=/opt/gimli/gimli:$PYTHONPATH
    export LD_LIBRARY_PATH=/opt/gimli/build/lib:$LD_LIBRARY_PATH
    export PATH=/opt/gimli/build/bin:$PATH
    export PROMPT_DIRTRIM=2
    export PS1='[\u@\h \w]\$ '
